    <unit id="setup.step.provider">
      <segment state="final">
        <source>Create or activate a provider and model in the nr_llm module.</source>
        <target>Legen Sie im nr_llm-Modul einen Provider und ein Modell an oder aktivieren Sie bestehende Einträge.</target>
      </segment>
