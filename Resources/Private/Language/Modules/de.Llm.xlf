        <target>LLM-Konfigurationen für Solr verwenden</target>
      </segment>
    </unit>
    <unit id="description">
      <segment state="final">
        <source>Connect Solr search with provider-agnostic nr_llm configurations for query enhancement and diagnostics.</source>
        <target>Verbindet die Solr-Suche mit providerunabhängigen nr_llm-Konfigurationen für Query-Optimierung und Diagnose.</target>
      </segment>
    </unit>
