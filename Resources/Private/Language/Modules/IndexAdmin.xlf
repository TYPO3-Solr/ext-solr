<?xml version="1.0" encoding="UTF-8"?>
<xliff version="2.0" xmlns="urn:oasis:names:tc:xliff:document:2.0" srcLang="en">
  <file id="f1">
    <unit id="title">
      <segment state="final">
        <source>Index Administration</source>
      </segment>
    </unit>
    <unit id="short_description">
      <segment state="final">
        <source>Maintain Solr indexes and queues</source>
      </segment>
    </unit>
    <unit id="description">
      <segment state="final">
        <source>Manage Solr core configuration, Solr documents, and TYPO3 Index Queue entries for the selected site.</source>
      </segment>
    </unit>
    <unit id="card.reload.title">
      <segment state="final">
        <source>Reload Core Configuration</source>
      </segment>
    </unit>
    <unit id="card.reload.subtitle">
      <segment state="final">
        <source>Solr core settings</source>
      </segment>
    </unit>
    <unit id="card.reload.description">
      <segment state="final">
        <source>Reload the selected site's Solr cores after changing synonyms, stop words, protected words, or other core/index configuration.</source>
      </segment>
    </unit>
    <unit id="card.reload.button">
      <segment state="final">
        <source>Reload Configuration</source>
      </segment>
    </unit>
    <unit id="card.emptyIndex.title">
      <segment state="final">
        <source>Empty Index</source>
      </segment>
    </unit>
    <unit id="card.emptyIndex.subtitle">
      <segment state="final">
        <source>Indexed Solr documents</source>
      </segment>
    </unit>
    <unit id="card.emptyIndex.description">
      <segment state="final">
        <source>Remove only the selected site's documents from Solr, even when several sites share one index.</source>
      </segment>
    </unit>
    <unit id="card.emptyIndex.button">
      <segment state="final">
        <source>Empty Index</source>
      </segment>
    </unit>
    <unit id="card.clearQueue.title">
      <segment state="final">
        <source>Clear Index Queue</source>
      </segment>
    </unit>
    <unit id="card.clearQueue.subtitle">
      <segment state="final">
        <source>TYPO3 queue entries</source>
      </segment>
    </unit>
    <unit id="card.clearQueue.description">
      <segment state="final">
        <source>Empty the selected site's Index Queue entries. Re-initialize the queue afterwards to build it again.</source>
      </segment>
    </unit>
    <unit id="card.clearQueue.button">
      <segment state="final">
        <source>Clear Index Queue</source>
      </segment>
    </unit>
    <unit id="modal.confirm.title">
      <segment state="final">
        <source>Please confirm</source>
      </segment>
    </unit>
    <unit id="modal.emptyIndex.content">
      <segment state="final">
        <source>Are you sure you want to empty the index? All Solr documents for this site will be removed.</source>
      </segment>
    </unit>
    <unit id="modal.clearQueue.content">
      <segment state="final">
        <source>Are you sure you want to clear the Index Queue?</source>
      </segment>
    </unit>
    <unit id="flash.indexEmptied">
      <segment state="final">
        <source>Index emptied for site "{site}" ({cores}).</source>
      </segment>
    </unit>
    <unit id="flash.queueEmptied">
      <segment state="final">
        <source>Index Queue emptied for site "{site}".</source>
      </segment>
    </unit>
    <unit id="flash.emptyIndexError">
      <segment state="final">
        <source>An error occurred while deleting documents from the index: {error}</source>
      </segment>
    </unit>
    <unit id="flash.reloadFailed">
      <segment state="final">
        <source>Failed to reload index configuration for core "{core}".</source>
      </segment>
    </unit>
    <unit id="flash.reloaded">
      <segment state="final">
        <source>{count, plural, one {Core configuration reloaded for # core ({cores}).} other {Core configuration reloaded for # cores ({cores}).}}</source>
      </segment>
    </unit>
  </file>
</xliff>
