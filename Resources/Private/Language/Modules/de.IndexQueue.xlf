    <unit id="description">
      <segment state="final">
        <source>Check Index Queue status, initialize content for indexing, clear entries, and requeue failed or outdated items.</source>
        <target>Prüfen Sie den Status der Index-Queue, initialisieren Sie Inhalte für die Indexierung, leeren Sie Einträge und stellen Sie fehlgeschlagene oder veraltete Elemente erneut ein.</target>
      </segment>
    </unit>
