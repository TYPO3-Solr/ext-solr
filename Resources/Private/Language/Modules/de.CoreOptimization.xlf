    <unit id="module.teaser">
      <segment state="final">
        <source>Maintain synonyms and stop words for the selected Solr cores to improve search results.</source>
        <target>Pflegen Sie Synonyme und Stoppwörter für die ausgewählten Solr-Cores, um die Suchergebnisse zu verbessern.</target>
      </segment>
    </unit>
