    <unit id="description">
      <segment state="final">
        <source>Maintain synonyms and stop words for Solr cores to improve search results.</source>
        <target>Pflegen Sie Synonyme und Stoppwörter für Solr-Cores, um die Suchergebnisse zu verbessern.</target>
      </segment>
    </unit>
